﻿@model IEnumerable<UC000608.Models.TipoPlano>

<div class="container mt-4">
    <h2>Tipos de Plano</h2>

    <a class="btn btn-primary mb-3" asp-action="Create">Criar Novo Tipo</a>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Desconto (%)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tipo in Model)
            {
                <tr>
                    <td>@tipo.Nome</td>
                    <td>@tipo.Desconto%</td>
                </tr>
            }
        </tbody>
    </table>
</div>
